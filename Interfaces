using System;

namespace InterfacesTask
{
    interface IOutput
    {
        void Show();
        void Show(string info);
    }

    interface IMath
    {
        int Max();
        int Min();
        float Avg();
        bool Search(int valueToSearch);
    }

    class Array : IOutput, IMath
    {
        private int[] arr;

        public Array(int[] arr)
        {
            this.arr = arr;
        }

        public void Show()
        {
            foreach (int item in arr)
            {
                Console.Write(item + " ");
            }
            Console.WriteLine();
        }

        public void Show(string info)
        {
            Console.WriteLine(info);
            foreach (int item in arr)
            {
                Console.Write(item + " ");
            }
            Console.WriteLine();
        }

        public int Max()
        {
            int max = arr[0];

            foreach (int item in arr)
            {
                if (item > max)
                    max = item;
            }

            return max;
        }

        public int Min()
        {
            int min = arr[0];

            foreach (int item in arr)
            {
                if (item < min)
                    min = item;
            }

            return min;
        }

        public float Avg()
        {
            int sum = 0;

            foreach (int item in arr)
            {
                sum += item;
            }

            return (float)sum / arr.Length;
        }

        public bool Search(int valueToSearch)
        {
            foreach (int item in arr)
            {
                if (item == valueToSearch)
                    return true;
            }

            return false;
        }
    }

    class Program
    {
        static void Main(string[] args)
        {
            int[] numbers = { 10, 25, 7, 45, 18, 30 };

            Array array = new Array(numbers);

            Console.WriteLine("Show():");
            array.Show();

            Console.WriteLine();

            Console.WriteLine("Show(string info):");
            array.Show("Elements of array:");

            Console.WriteLine();

            Console.WriteLine("Max = " + array.Max());
            Console.WriteLine("Min = " + array.Min());
            Console.WriteLine("Avg = " + array.Avg());

            Console.WriteLine();

            Console.WriteLine("Search 45: " + array.Search(45));
            Console.WriteLine("Search 100: " + array.Search(100));

            Console.ReadKey();
        }
    }
}
