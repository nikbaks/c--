#include <iostream>
#include <string>
#include <vector>

class Engine {
private:
    int horsepower;
public:
    Engine(int hp) : horsepower(hp) {}
    void start() {
        std::cout << "Engine started. HP: " << horsepower << std::endl;
    }
};

class Wheel {
private:
    int size;
public:
    Wheel(int s) : size(s) {}
    void rotate() {
        std::cout << "Wheel " << size << " is rotating." << std::endl;
    }
};

class Car {
private:
    std::string brand;
    Engine engine;
    std::vector<Wheel*> wheels;

public:
    Car(std::string b, int hp, Wheel* w1, Wheel* w2, Wheel* w3, Wheel* w4) 
        : brand(b), engine(hp) {
        wheels.push_back(w1);
        wheels.push_back(w2);
        wheels.push_back(w3);
        wheels.push_back(w4);
    }

    void drive() {
        std::cout << "Car: " << brand << std::endl;
        engine.start();
        for (auto wheel : wheels) {
            wheel->rotate();
        }
    }
};

int main() {
    Wheel w1(17), w2(17), w3(17), w4(17);
    Car myCar("BMW", 250, &w1, &w2, &w3, &w4);
    myCar.drive();
    return 0;
}
